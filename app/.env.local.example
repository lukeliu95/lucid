# kdsj-world env example
NEXT_PUBLIC_SITE_URL=http://localhost:3000
USE_MOCK_API=false

# --- DB (Neon Postgres + pgvector) ---
DATABASE_URL=

# --- LLM (DeepSeek · Edge Function only) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FALLBACK_MODEL=deepseek-chat

# --- Embeddings (OpenAI · server-side only) ---
OPENAI_API_KEY=

# --- Auth (Clerk · wire in D6) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Admin allow-list (comma-separated Clerk userIds, or "*" for dev) ---
ADMIN_USER_IDS=
